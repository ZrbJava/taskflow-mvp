generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

enum TaskStatus {
  todo
  doing
  done
}

enum TaskPriority {
  none
  low
  medium
  high
  urgent
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  tasks        Task[]
  /// 作为负责人被指派的任务（MVP 仅支持指派给任务所有者本人）
  assignedTasks Task[]    @relation("TaskAssignee")
  projects     Project[]
  labels       Label[]
  comments     Comment[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(none)
  dueDate     DateTime?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 负责人（当前仅允许为空或等于 `userId`，为多人协作预留字段）
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  labels      Label[]
  comments    Comment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, dueDate])
  @@index([userId, assigneeId])
}

/// 用户维度的标签，用于跨项目归类任务（对标 Linear Labels / Jira 标签）。
model Label {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  color  String?
  tasks  Task[]

  @@unique([userId, name])
  @@index([userId])
}

/// 任务下的讨论串（对标 issue comment）。
model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, createdAt])
}
