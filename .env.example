# PostgreSQL（推荐开发与生产一致）
# 本地示例（请按你的用户名/密码/库名修改）：
# postgresql://postgres:postgres@localhost:5432/taskflow_mvp?schema=public
# Neon / Supabase 直接粘贴控制台提供的连接串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskflow_mvp?schema=public"

# Auth.js：开发可用任意非空字符串；生产请使用 openssl rand -base64 32
AUTH_SECRET="请替换为随机长字符串"

# 生产部署到 Vercel 时，直接将 DATABASE_URL 设置为托管 PG 连接串即可

# Vercel Cron 调用 `/api/cron/due-reminders` 时校验；与 Vercel 项目环境变量同名即可
# CRON_SECRET="openssl rand -base64 32"
